# Django Settings Configuration
# Copy this file to .env and configure the variables for local development.

# Security warning: keep the secret key used in production secret!
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production

# Security warning: don't run with debug turned on in production!
DEBUG=True

# Comma-separated list of hosts/domain names that this Django site can serve
# e.g. ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of origins that are authorized to make cross-site HTTP requests
# e.g. CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database connection URL
# PostgreSQL (Neon/Render): postgres://user:password@host:port/dbname
# If not provided, development settings will default to local SQLite.
DATABASE_URL=
